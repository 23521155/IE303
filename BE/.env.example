# Copy file này thành .env trên VPS và điền giá trị thật
# Không commit file .env lên git

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Chuỗi ngẫu nhiên >= 32 ký tự, giống nhau ở mọi service
JWT_SECRET=change-this-to-a-long-random-secret-key-32chars

# ─── CORS ────────────────────────────────────────────────────────────────────
# Domain frontend (không có dấu / ở cuối)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Username và password dùng chung cho mọi service (cùng cluster Neon)
DB_USERNAME=neondb_owner
DB_PASSWORD=change-this-to-real-neon-password

# URL riêng cho từng service (thay <host> bằng endpoint Neon của bạn)
AUTH_DB_URL=jdbc:postgresql://<host>:5432/auth_db?sslmode=require
USER_DB_URL=jdbc:postgresql://<host>:5432/user_db?sslmode=require
MATERIAL_DB_URL=jdbc:postgresql://<host>:5432/material_db?sslmode=require
EXAM_DB_URL=jdbc:postgresql://<host>/exam_db?sslmode=require&channelBinding=require
